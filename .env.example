# =====================================================================
# encorewoodcrafts.in environment variables
#
# Copy to .env.local for local development (it's gitignored).
# In production, set these in the Vercel dashboard:
#   Vercel → Project → Settings → Environment Variables
# =====================================================================

# -- public site URL (used by metadataBase, sitemap, robots, og images) --
# Local dev   : http://localhost:3000
# Vercel prev : https://encorewoodcrafts.vercel.app
# Production  : https://encorewoodcrafts.in   (once domain is connected)
NEXT_PUBLIC_SITE_URL=https://encorewoodcrafts.vercel.app

# -- transactional email via Resend --------------------------------------
# Get a key at https://resend.com → API Keys
# Until you verify a sending domain, use the test sender below for FROM
#   FROM (test) : onboarding@resend.dev   (sends only to your account email)
#   FROM (prod) : noreply@encorewoodcrafts.in   (after DNS verification)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxx

# Where quote-form leads are sent. Should be a real inbox you check daily.
ENCORE_QUOTES_EMAIL=studio@encorewoodcrafts.in

# Sender address shown on outgoing mail. Must be a verified Resend domain.
ENCORE_FROM_EMAIL=studio@encorewoodcrafts.in
